<view class="projects">
  <view class="projects__head">
    <view class="projects__title">项目</view>
  </view>

  <view wx:if="{{loading}}" class="projects__loading">加载中…</view>
  <view wx:elif="{{projects.length === 0}}" class="projects__empty">还没有项目，点右下角「＋」开始</view>

  <view wx:else class="projects__grid">
    <view wx:for="{{projects}}" wx:key="project_id" class="ring-item card" data-id="{{item.project_id}}" bindtap="toggle" bindlongpress="confirmDelete">
      <!-- streak 持续型：不显示进度圆环，显示势头 -->
      <block wx:if="{{item.mode === 'streak'}}">
        <view class="streak">
          <view class="streak__days">{{item.streak_days || 0}}</view>
          <view class="streak__label">连续达标天</view>
        </view>
        <view class="ring-item__name">{{item.name}}</view>
        <view class="ring-item__count">本周 {{item.week_met_days || 0}}/7 · 累计 {{item.total_done || 0}} 件</view>
      </block>
      <!-- result 结果型：数值进度条 -->
      <block wx:elif="{{item.mode === 'result'}}">
        <view class="result">
          <view class="result__val">{{item.current_value || 0}}<text class="result__unit">{{item.goal_unit}}</text></view>
          <view class="result__bar"><view class="result__fill" style="width:{{item.percent}}%;background:{{item.color}}"></view></view>
          <view class="result__goal">目标 {{item.goal_target}}{{item.goal_unit}}</view>
        </view>
        <view class="ring-item__name">{{item.name}}</view>
        <view class="result__record" data-id="{{item.project_id}}" catchtap="recordValue">＋ 记一笔</view>
      </block>
      <!-- count 有限型（含旧数据/随手记）：沿用圆环 -->
      <block wx:else>
        <view class="ring-item__canvas-wrap">
          <canvas type="2d" id="ring-{{item.project_id}}" class="ring-item__canvas"></canvas>
          <view class="ring-item__percent">{{item.percent}}%</view>
        </view>
        <view class="ring-item__name">{{item.name}}</view>
        <view class="ring-item__count">{{item.completed_tasks}}{{item.goal_target ? '/' + item.goal_target : '/' + item.total_tasks}}</view>
      </block>

      <view wx:if="{{activeId === item.project_id}}" class="dots">
        <block wx:for="{{activeGroups}}" wx:for-item="g" wx:key="index">
          <view wx:if="{{g.is_group}}" class="group">
            <view class="group__title">📌 {{g.parent_action}}</view>
            <view wx:for="{{g.steps}}" wx:for-item="t" wx:key="task_id" class="dotrow dotrow--step">
              <view class="dot dot--{{t.status}}"></view>
              <text class="dotrow__action">{{t.action}}</text>
            </view>
          </view>
          <view wx:else class="dotrow">
            <view class="dot dot--{{g.status}}"></view>
            <text class="dotrow__action">{{g.action}}</text>
          </view>
        </block>

        <!-- 项目内加任务：一键同步今日清单 -->
        <block wx:if="{{addingId === item.project_id}}">
          <view class="addbox" catchtap="stopPropagation">
            <input class="addbox__input" placeholder="加一件事，自动进今日清单" value="{{addAction}}" bindinput="onAddInput" maxlength="100" confirm-type="done" bindconfirm="submitAdd" />
            <view class="addbox__row">
              <view class="addbox__repeat">
                <text class="addbox__repeat-label">每日重复</text>
                <switch checked="{{addRepeat}}" bindchange="onRepeatToggle" color="{{item.color}}" style="transform:scale(0.8)" />
              </view>
              <view class="addbox__btns">
                <text class="addbox__btn" catchtap="closeAdd">取消</text>
                <text class="addbox__btn addbox__btn--primary" catchtap="submitAdd">加入</text>
              </view>
            </view>
          </view>
        </block>
        <view wx:else class="addbox__open" data-id="{{item.project_id}}" catchtap="openAdd">＋ 加任务</view>
      </view>
    </view>
  </view>

  <!-- 新建项目面板 -->
  <view wx:if="{{showCreate}}" class="modal-mask" bindtap="closeCreate">
    <view class="modal" catchtap="stopPropagation">
      <view class="modal__title">新建项目</view>
      <input class="modal__input" placeholder-class="modal__input-ph" placeholder="项目名，如：视频号运营" value="{{newName}}" bindinput="onNameInput" maxlength="30" />

      <view class="modal__label">用什么来衡量推进</view>
      <view class="mode-tabs">
        <view class="mode-tab {{newMode === 'count' ? 'mode-tab--on' : ''}}" data-mode="count" bindtap="pickMode">
          <view class="mode-tab__name">计数</view>
          <view class="mode-tab__desc">有终点，如读100本书</view>
        </view>
        <view class="mode-tab {{newMode === 'streak' ? 'mode-tab--on' : ''}}" data-mode="streak" bindtap="pickMode">
          <view class="mode-tab__name">坚持</view>
          <view class="mode-tab__desc">持续运营，如日更视频</view>
        </view>
        <view class="mode-tab {{newMode === 'result' ? 'mode-tab--on' : ''}}" data-mode="result" bindtap="pickMode">
          <view class="mode-tab__name">数值</view>
          <view class="mode-tab__desc">数字目标，如涨粉到1万</view>
        </view>
      </view>

      <block wx:if="{{newMode === 'count'}}">
        <input class="modal__input" placeholder-class="modal__input-ph" type="number" placeholder="目标件数，如 100" value="{{newGoal}}" bindinput="onGoalInput" />
      </block>
      <block wx:elif="{{newMode === 'streak'}}">
        <input class="modal__input" placeholder-class="modal__input-ph" type="number" placeholder="每日标准，如 1（日更1个）" value="{{newQuota}}" bindinput="onQuotaInput" />
      </block>
      <block wx:elif="{{newMode === 'result'}}">
        <input class="modal__input" placeholder-class="modal__input-ph" type="number" placeholder="目标数值，如 10000" value="{{newGoal}}" bindinput="onGoalInput" />
        <input class="modal__input" placeholder-class="modal__input-ph" placeholder="单位，如 元 / 粉丝" value="{{newUnit}}" bindinput="onUnitInput" maxlength="10" />
      </block>

      <view class="modal__actions">
        <view class="modal__btn modal__btn--ghost" bindtap="closeCreate">取消</view>
        <view class="modal__btn modal__btn--primary" bindtap="submitCreate">创建</view>
      </view>
    </view>
  </view>

  <!-- 右下角新建项目悬浮按钮 -->
  <view class="fab" bindtap="openCreate">＋</view>
</view>

