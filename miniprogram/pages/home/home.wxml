<view class="home">
  <!-- 进度胶囊（点击可调每日可投入时长） -->
  <view class="capsule" bindtap="openCapModal">
    <view class="capsule__label">今日剩余可支配创造力</view>
    <view class="capsule__value">{{remainLabel}}</view>
  </view>

  <!-- 当前任务 / 空态 -->
  <view class="home__body">
    <block wx:if="{{currentGroup}}">
      <!-- 当前执行单元：大任务组 -->
      <view wx:if="{{currentGroup.is_group}}" class="taskcard card taskcard--group">
        <view class="taskcard__tag">{{currentGroup.steps[0].project_tag || '大事'}}</view>
        <view class="taskcard__action">{{currentGroup.parent_action}}</view>
        <view wx:if="{{currentGroup.steps[0].vision_statement}}" class="taskcard__vision">{{currentGroup.steps[0].vision_statement}}</view>
        <view class="taskcard__meta">共 {{currentGroup.step_total}} 步 · 还剩 {{currentGroup.remain_steps}} 步 · 预估 {{currentGroup.total_duration}} 分钟</view>
        <!-- 子任务清单（缩进），不带各自时间 -->
        <view class="substeps">
          <view wx:for="{{currentGroup.steps}}" wx:key="task_id" class="substep">
            <view class="substep__dot"></view>
            <view class="substep__action">{{item.action}}</view>
            <view class="substep__done" catchtap="completeSubstep" data-id="{{item.task_id}}">✓</view>
          </view>
        </view>
        <view class="taskcard__btns">
          <button class="btn-primary taskcard__start" data-parent="{{currentGroup.parent_task_id}}" bindtap="startGroup">开始专注</button>
          <view class="taskcard__del" catchtap="deleteGroup" data-parent="{{currentGroup.parent_task_id}}">删除整件</view>
        </view>
      </view>
      <!-- 当前执行单元：单任务 -->
      <view wx:else class="taskcard card">
        <view class="taskcard__tag">{{currentGroup.project_tag}}</view>
        <view class="taskcard__action">{{currentGroup.action}}</view>
        <view class="taskcard__vision">{{currentGroup.vision_statement}}</view>
        <view class="taskcard__meta">预估 {{currentGroup.duration}} 分钟</view>
        <view class="taskcard__btns">
          <button class="btn-primary taskcard__start" bindtap="startTask">开始</button>
          <button class="taskcard__done" catchtap="completeDirect" data-id="{{currentGroup.task_id}}">✓ 完成</button>
          <view class="taskcard__del" catchtap="deletePending" data-id="{{currentGroup.task_id}}">删除</view>
        </view>
      </view>
      <view class="home__count">{{coachLine}}</view>

      <!-- 今日待办列表：按大任务分组 -->
      <view wx:if="{{nextGroups.length}}" class="queue">
        <view class="queue__title">接下来</view>
        <block wx:for="{{nextGroups}}" wx:key="index" wx:for-item="g">
          <!-- 大任务组：父标题 + 缩进子任务 -->
          <view wx:if="{{g.is_group}}" class="queue__group">
            <view class="queue__group-head" data-parent="{{g.parent_task_id}}" bindtap="selectGroup">
              <view class="queue__dot queue__dot--group"></view>
              <view class="queue__action">{{g.parent_action}}</view>
              <view class="queue__dur">{{g.remain_steps}}步 · {{g.total_duration}}分</view>
              <view class="queue__del" catchtap="deleteGroup" data-parent="{{g.parent_task_id}}">×</view>
            </view>
            <view wx:for="{{g.steps}}" wx:key="task_id" wx:for-item="s" class="queue__substep">
              <view class="substep__dot"></view>
              <view class="substep__action">{{s.action}}</view>
              <view class="queue__done" catchtap="completeSubstep" data-id="{{s.task_id}}">✓</view>
            </view>
          </view>
          <!-- 独立任务 -->
          <view wx:else class="queue__item" data-id="{{g.task_id}}" bindtap="selectTask">
            <view class="queue__dot"></view>
            <view class="queue__action">{{g.action}}</view>
            <view class="queue__dur">{{g.duration}}分</view>
            <view class="queue__done" catchtap="completeDirect" data-id="{{g.task_id}}">✓</view>
            <view class="queue__del" catchtap="deletePending" data-id="{{g.task_id}}">×</view>
          </view>
        </block>
      </view>
    </block>
    <view wx:else class="home__empty">今天清空了，牛。</view>

    <!-- 已完成 / 跳过：划线留痕，用户自己删，不自动消失 -->
    <view wx:if="{{doneTasks.length}}" class="done">
      <view class="done__head">
        <view class="done__title">已完成</view>
        <view class="done__clear" bindtap="clearDone">清空</view>
      </view>
      <view wx:for="{{doneTasks}}" wx:key="task_id" class="done__item {{item.status === 'skip' ? 'done__item--skip' : ''}}">
        <view class="done__action">{{item.action}}</view>
        <view class="done__del" catchtap="deleteDone" data-id="{{item.task_id}}">×</view>
      </view>
    </view>
  </view>

  <!-- 全局大按钮 -->
  <view class="bigbtn" bindtap="openInput">＋</view>

  <!-- 输入面板 -->
  <view wx:if="{{showInput}}" class="mask" bindtap="closeInput">
    <view class="panel" catchtap="noop">
      <block wx:if="{{!parseCard}}">
        <textarea class="panel__input" placeholder="此刻在想什么？写下来交给 AI"
                  value="{{inputText}}" bindinput="onInput" maxlength="500" auto-height focus />
        <view class="panel__split">
          <text class="panel__split-label">大事帮我拆成几步</text>
          <switch checked="{{allowSplit}}" color="#7A9E7E" bindchange="onToggleSplit" />
        </view>
        <view class="panel__row">
          <button class="btn-primary panel__send" loading="{{parsing}}" bindtap="submitInput">{{allowSplit ? '交给 AI 拆解' : '快速添加'}}</button>
        </view>
      </block>

      <!-- 确认卡片 -->
      <view wx:else class="confirm">
        <view class="confirm__title">{{parseCard.is_big_task ? '这件事有点大，帮你拆成几步' : '确认一下'}}</view>

        <!-- 大事：展示拆分小步 -->
        <block wx:if="{{parseCard.is_big_task}}">
          <view class="confirm__field"><text>项目</text><view>{{parseCard.project_tag}}</view></view>
          <view class="subtasks">
            <view wx:for="{{parseCard.subtasks}}" wx:key="index" class="subtask">
              <view class="subtask__idx">{{index + 1}}</view>
              <view class="subtask__action">{{item.action}}</view>
            </view>
          </view>
        </block>

        <!-- 单任务 -->
        <block wx:else>
          <view class="confirm__field"><text>任务</text><view>{{parseCard.action}}</view></view>
          <view class="confirm__field"><text>耗时</text><view>{{parseCard.duration}} 分钟</view></view>
          <view class="confirm__field"><text>项目</text><view>{{parseCard.project_tag}}</view></view>
        </block>

        <view class="confirm__vision">{{parseCard.vision_statement}}</view>
        <view class="confirm__btns">
          <button class="confirm__cancel" bindtap="closeInput">取消</button>
          <button class="btn-primary confirm__ok" bindtap="confirmCard">{{parseCard.is_big_task ? '全部加入今日' : '加入今日'}}</button>
        </view>
      </view>
    </view>
  </view>

  <!-- 容量饱和 -->
  <view wx:if="{{overflowTask}}" class="mask">
    <view class="dialog">
      <view class="dialog__text">今天已满，要移到明天吗？</view>
      <view class="dialog__btns">
        <button class="dialog__no" bindtap="forceToday">今天硬塞</button>
        <button class="btn-primary dialog__yes" bindtap="confirmMoveTomorrow">移到明天</button>
      </view>
    </view>
  </view>

  <!-- 每日可投入时长调节：自由输入 + 快捷档 -->
  <view wx:if="{{showCapModal}}" class="mask" bindtap="closeCapModal">
    <view class="caphours" catchtap="noop">
      <view class="caphours__title">每天大概能投入多少？</view>
      <view class="caphours__hint">填你自己的数字，改完今日额度立即重算，之后系统仍会按实际完成情况校准</view>
      <view class="caphours__inputrow">
        <input class="caphours__input" type="digit" placeholder="如 6"
               value="{{capHoursInput}}" bindinput="onCapHoursInput" focus="{{showCapModal}}" />
        <text class="caphours__unit">小时 / 天</text>
      </view>
      <view class="caphours__chips">
        <text wx:for="{{workHoursOptions}}" wx:key="value"
              class="caphours__chip" data-h="{{item.value}}" bindtap="fillCapHours">{{item.label}}</text>
      </view>
      <button class="btn-primary caphours__ok" bindtap="submitCapHours">确定</button>
    </view>
  </view>
</view>
